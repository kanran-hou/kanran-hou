/* ============================================================
   CopyMind 历史记录页 — 样式
============================================================ */
page {
  --primary: #4A7CF7;
  --bg: #F5F6FA;
  --text: #1A1A2E;
  --text-secondary: #6B7280;
  --text-light: #9CA3AF;
  --border: #EEEEEE;
  --radius-card: 16rpx;
  --padding-h: 24rpx;
  --section-gap: 24rpx;
  background: var(--bg);
  font-family: -apple-system,"PingFang SC","Microsoft YaHei",sans-serif;
  color: var(--text);
}

.page { display: flex; flex-direction: column; min-height: 100vh; background: var(--bg); }

/* 顶部导航 */
.nav-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx var(--padding-h); background: #fff; position: sticky; top: 0; z-index: 10;
}
.nav-back { display: flex; align-items: center; gap: 6rpx; padding: 10rpx 0; }
.nav-back-icon { font-size: 40rpx; line-height: 1; color: var(--text); }
.nav-back-text { font-size: 28rpx; color: var(--text); }
.nav-title { font-size: 32rpx; font-weight: 700; color: var(--text); }
.nav-placeholder { width: 80rpx; }

.scroll-area { flex: 1; -webkit-overflow-scrolling: touch; }

/* 统计栏 */
.stats-bar {
  display: flex; justify-content: space-around; padding: 24rpx var(--padding-h); background: #fff;
  margin: 0 0 16rpx 0;
}
.stat-item { text-align: center; }
.stat-num { font-size: 36rpx; font-weight: 800; color: var(--primary); display: block; }
.stat-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

/* 列表项 */
.history-list { padding: 0 var(--padding-h); }
.history-card {
  background: #fff; border-radius: var(--radius-card); padding: 28rpx 24rpx;
  margin-bottom: 16rpx; display: flex; flex-direction: column; gap: 14rpx;
}
.history-card:active { opacity: 0.85; }
.history-top {
  display: flex; justify-content: space-between; align-items: flex-start; gap: 12rpx;
}
.history-excerpt {
  font-size: 28rpx; font-weight: 500; color: var(--text); line-height: 1.5;
  flex: 1; overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.history-score {
  font-size: 36rpx; font-weight: 800; white-space: nowrap; flex-shrink: 0;
}
.history-bottom {
  display: flex; justify-content: space-between; align-items: center;
}
.history-tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.history-tag {
  font-size: 22rpx; color: var(--primary); background: #EEF2FF;
  padding: 4rpx 16rpx; border-radius: 8rpx;
}
.history-time {
  font-size: 22rpx; color: var(--text-light); white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: var(--text-light); }
.empty-btn {
  margin-top: 30rpx; padding: 20rpx 48rpx; background: var(--primary);
  color: #fff; border-radius: 24rpx; font-size: 28rpx; font-weight: 600;
}

/* 加载更多 */
.load-more { text-align: center; padding: 30rpx 0 40rpx; }
.load-more text { font-size: 24rpx; color: var(--text-light); }
.bottom-spacer { height: 40rpx; }
