<!-- ============================================================
  CopyMind 历史记录页
============================================================ -->
<view class="page">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-icon">‹</text>
      <text class="nav-back-text">返回</text>
    </view>
    <text class="nav-title">分析记录</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 统计栏 -->
  <view class="stats-bar" wx:if="{{list.length > 0}}">
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">总记录</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{avgScore}}</text>
      <text class="stat-label">平均分</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{bestScore}}</text>
      <text class="stat-label">最高分</text>
    </view>
  </view>

  <scroll-view class="scroll-area" scroll-y bindscrolltolower="onLoadMore">

    <!-- 列表 -->
    <view class="history-list" wx:if="{{list.length > 0}}">
      <view
        class="history-card"
        wx:for="{{list}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onItemTap"
      >
        <view class="history-top">
          <text class="history-excerpt">{{item.excerpt}}</text>
          <text class="history-score" style="color:{{getScoreColor(item.score)}}">{{item.score}}</text>
        </view>
        <view class="history-bottom">
          <view class="history-tags">
            <text class="history-tag">{{item.trackName}}</text>
            <text class="history-tag">{{item.grade}}级</text>
          </view>
          <text class="history-time">{{item.time}}</text>
        </view>
      </view>

      <view class="load-more" wx:if="{{hasMore}}">
        <text>加载更多…</text>
      </view>
      <view class="load-more" wx:elif="{{list.length > 0}}">
        <text>已显示全部记录</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无分析记录</text>
      <view class="empty-btn" bindtap="goAnalyze">去分析文案</view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
