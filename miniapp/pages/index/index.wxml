<!-- ============================================================
  CopyMind 文案录入首页 — 美化版
  改动：间距优化、2x2赛道卡片、底部固定按钮、安全区适配
============================================================ -->

<view class="page">

  <!-- ====== 滚动内容区（避开底部固定按钮） ====== -->
  <scroll-view class="scroll-area" scroll-y>

    <!-- 顶部留白 -->
    <view class="top-spacer"></view>

    <!-- ====== 赛道选择模块 ====== -->
    <view class="section">
      <text class="section-title">选择赛道</text>
      <view class="track-grid">
        <view
          wx:for="{{trackList}}"
          wx:key="id"
          class="track-card {{selectedTrack === item.id ? 'track-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onTrackSelect"
        >
          <text class="track-emoji">{{item.icon}}</text>
          <text class="track-label">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- ====== 文案输入模块 ====== -->
    <view class="section">
      <text class="section-title">输入文案</text>
      <textarea
        class="input-area"
        placeholder="在此粘贴或输入文案内容……"
        value="{{inputText}}"
        bindinput="onTextInput"
        maxlength="5000"
        auto-height
        show-confirm-bar="{{false}}"
      ></textarea>
      <view class="input-footer">
        <text class="char-count">{{inputText.length}} / 5000 字</text>
      </view>
    </view>

    <!-- ====== 图片上传模块 ====== -->
    <view class="section section-upload">
      <view class="upload-row">
        <view class="upload-btn" bindtap="onUploadImage">
          <text class="upload-icon">🖼</text>
          <text class="upload-text">上传图片</text>
        </view>
        <text wx:if="{{imageList.length > 0}}" class="upload-count">已选 {{imageList.length}} 张</text>
      </view>
      <view wx:if="{{imageList.length > 0}}" class="image-preview-list">
        <view wx:for="{{imageList}}" wx:key="index" class="image-preview-item">
          <image class="preview-img" src="{{item}}" mode="aspectFill" />
          <view class="img-remove" data-index="{{index}}" bindtap="onRemoveImage">✕</view>
        </view>
      </view>
    </view>

    <!-- ====== 底部说明 ====== -->
    <view class="footer-tip">
      <text>支持 4 种赛道文案分析 · AI 自动识别文案特征</text>
      <text>生成 5 维度评分 + 优化建议</text>
    </view>

    <view class="bottom-safe-spacer"></view>
  </scroll-view>

  <!-- ====== 底部固定按钮 ====== -->
  <view class="btn-fixed-wrap">
    <button
      class="btn-analyze {{canAnalyze ? '' : 'btn-disabled'}}"
      disabled="{{!canAnalyze}}"
      loading="{{isAnalyzing}}"
      bindtap="onAnalyze"
    >{{isAnalyzing ? '分析中...' : 'AI 一键分析'}}</button>
  </view>

  <!-- ====== 加载遮罩 ====== -->
  <view wx:if="{{showLoading}}" class="loading-overlay">
    <view class="loader"></view>
    <text class="loading-text">AI 分析中</text>
    <text class="loading-sub">正在提取文案特征，请稍候……</text>
  </view>

</view>
