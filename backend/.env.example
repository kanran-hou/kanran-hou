# CopyMind 后端环境变量配置
# 复制此文件为 .env 并填入你的配置

# 数据库连接（MySQL 8.0+）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=copymind

# AI 大模型 API Key（至少配置一个主用模型）
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=

# AI 大模型 URL（可选，默认使用官方 API 地址）
DEEPSEEK_API_URL=https://api.deepseek.com
QWEN_API_URL=https://dashscope.aliyuncs.com
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4

# 主用模型（deepseek / qwen / glm）
PRIMARY_LLM=deepseek
BACKUP_LLM=qwen

# 服务端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 日志级别
LOG_LEVEL=INFO
