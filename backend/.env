 # CopyMind Backend — Environment Variables
 # 复制此文件为 .env 并填入真实值
 
 # === 运行环境 ===
 ENV=development
 DEBUG=true
 
 # === 数据库（MySQL） ===
 DB_HOST=127.0.0.1
 DB_PORT=3306
 DB_USER=root
 DB_PASSWORD=your_password_here
 DB_DATABASE=copymind
 
 # === AI API（DeepSeek / 通义千问 / 智谱） ===
 AI_API_KEY=sk-b57704924cdb40da8f80de5fad7c83f9
 AI_API_BASE=https://api.deepseek.com
 AI_MODEL=deepseek-chat
 
 # === REDIS（可选，用于限流 / 缓存） ===
 REDIS_URL=
 
 # === 日志 ===
 LOG_LEVEL=DEBUG
 LOG_FILE=logs/copymind.log
 
 # === CORS ===
 CORS_ORIGINS=["*"]
 
 # === 限流 ===
 RATE_LIMIT_PER_MINUTE=60
